# Copy to .env for local testing. Never commit the real .env file.

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional explicit override — forces every provider to mock regardless of
# what real credentials are set. Leave blank normally; each provider below
# auto-detects live vs. mock from its own credentials.
PROVIDER_MODE=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_SMS_WEBHOOK_URL=
TWILIO_VOICE_WEBHOOK_URL=

GOOGLE_SERVICE_ACCOUNT_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=Frontdesk <hello@buy-mos.com>

PAYMENTS_PROVIDER=paypal
ADMIN_TRIGGER_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_PLAN_ID_MONTHLY=
PAYPAL_PLAN_ID_ANNUAL=
PAYPAL_WEBHOOK_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
